{
  "manifest_version": 3,
  "name": "StudyMate — Notes & Quizzes",
  "version": "0.1.0",
  "description": "Turn a screenshot or video transcript into study notes and a quick quiz.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "StudyMate"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
